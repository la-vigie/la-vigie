{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "La Vigie",
  "version": "0.1.0",
  "identifier": "com.lavigie",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "La Vigie",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "media-src": "'self' blob:",
        "font-src": "'self' data:",
        "frame-src": "'none'",
        "object-src": "'none'"
      },
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "evermax",
    "copyright": "Copyright © 2026 evermax",
    "homepage": "https://github.com/evermax/la-vigie",
    "license": "MIT",
    "category": "DeveloperTool",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
