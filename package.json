    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
