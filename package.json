{
  "name": "la-vigie",
  "private": true,
  "version": "0.4.0",
  "description": "Local desktop app to manage parallel AI coding agents and their git worktrees",
  "author": "evermax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/la-vigie/la-vigie.git"
  },
  "homepage": "https://github.com/la-vigie/la-vigie",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
